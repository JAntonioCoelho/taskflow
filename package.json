{
  "name": "taskflow",
  "version": "1.0.0",
  "description": "Modern Task Manager with Dark/Light Mode",
  "main": "index.html",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint tests/",
    "lint:fix": "eslint tests/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "serve": "python -m http.server 8000"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JAntonioCoelho/taskflow.git"
  },
  "keywords": [
    "todo",
    "tasks",
    "productivity",
    "task-manager",
    "dark-mode",
    "localStorage"
  ],
  "author": "JAntonioCoelho",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.3.3"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "tests/**/*.js"
    ],
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.claude/"
    ]
  }
}
